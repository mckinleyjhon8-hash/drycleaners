# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored — never commit real keys.

# --- Booking form (n8n pipeline) ---
# The /book form posts to the n8n webhook, which saves the booking to Postgres
# (garment_concierge.bookings) and sends a Telegram alert to the founder.
# The form has a built-in default webhook URL, so this is OPTIONAL — set it only
# to override the endpoint (e.g. a new n8n instance). Add it to Vercel too if set.
NEXT_PUBLIC_N8N_BOOKING_WEBHOOK=https://primary-production-68f72.up.railway.app/webhook/garment-booking
