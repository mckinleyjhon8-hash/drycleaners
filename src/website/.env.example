# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored — never commit real keys.

# --- Booking notifications (optional, but needed for the form to email you) ---
# Sign up free at https://resend.com, verify your domain, create an API key.
RESEND_API_KEY=

# Where new collection requests are emailed (defaults to hello@thegarmentconcierge.co.uk)
BOOKINGS_INBOX=

# Verified "from" address on your Resend account.
# Until your domain is verified you can use: The Garment Concierge <onboarding@resend.dev>
BOOKINGS_FROM=
